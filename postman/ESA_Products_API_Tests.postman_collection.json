              "\r",
              "pm.test(\"Response has data array\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.have.property(\"data\");\r",
              "    pm.expect(json.data).to.be.an(\"array\");\r",
              "    pm.expect(json.data.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Each product has required fields\", function () {\r",
              "    const json = pm.response.json();\r",
              "    const firstProduct = json.data[0];\r",
              "    pm.expect(firstProduct).to.have.property(\"id\");\r",
              "    pm.expect(firstProduct).to.have.property(\"name\");\r",
              "    pm.expect(firstProduct).to.have.property(\"price\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
