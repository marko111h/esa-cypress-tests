    {
      "name": "05 - POST Product - Customer not authorized",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Customer cannot create product (security test)\", function () {\r",
              "    // Customer role should NOT be allowed to create products\r",
              "    // Expected: 401, 403, or 500 (depending on API implementation)\r",
              "    pm.expect(pm.response.code).to.be.oneOf([401, 403, 500]);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has error message\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.have.property(\"message\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "// Log the actual response for documentation\r",
              "console.log(\"Status:\", pm.response.code);\r",
              "console.log(\"Body:\", pm.response.text());"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
