    {
      "name": "01 - Login (Setup)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has access_token\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.have.property(\"access_token\");\r",
              "    pm.expect(json.access_token).to.be.a(\"string\");\r",
              "    pm.expect(json.access_token.length).to.be.greaterThan(20);\r",
              "});\r",
              "\r",
              "pm.test(\"Token type is Bearer\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.token_type).to.eql(\"bearer\");\r",
              "});\r",
              "\r",
              "// Save token to environment variable for next requests\r",
              "pm.test(\"Save access_token to environment\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.environment.set(\"accessToken\", json.access_token);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"email\": \"marko.qa.2026@test.com\",\r\n  \"password\": \"TestPass2026!\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/users/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "02 - Get Categories (Setup)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is an array\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.be.an(\"array\");\r",
              "    pm.expect(json.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Save first SUBCATEGORY id to environment\", function () {\r",
              "    const json = pm.response.json();\r",
              "    // Find first parent that has subcategories\r",
              "    const parentWithSubs = json.find(cat => cat.sub_categories && cat.sub_categories.length > 0);\r",
              "    if (parentWithSubs) {\r",
              "        const subcategoryId = parentWithSubs.sub_categories[0].id;\r",
              "        pm.environment.set(\"categoryId\", subcategoryId);\r",
              "        console.log(\"Saved subcategoryId:\", subcategoryId);\r",
              "    } else {\r",
              "        // Fallback to first category\r",
              "        pm.environment.set(\"categoryId\", json[0].id);\r",
              "        console.log(\"No subcategories found, using parent:\", json[0].id);\r",
              "    }\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
